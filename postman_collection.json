						"body": {
							"mode": "raw",
							"raw": "rohit@example.com"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/forgot-password",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"forgot-password"
							]
						}
					}
				}
			]
